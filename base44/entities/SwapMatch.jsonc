{
  "name": "SwapMatch",
  "type": "object",
  "properties": {
    "intentAId": {
      "type": "string",
      "description": "Reference to SwapIntent \u2014 Party A"
    },
    "intentBId": {
      "type": "string",
      "description": "Reference to SwapIntent \u2014 Party B"
    },
    "userAId": {
      "type": "string",
      "description": "Reference to User (Party A) \u2014 for convenience queries"
    },
    "userBId": {
      "type": "string",
      "description": "Reference to User (Party B)"
    },
    "propertyAId": {
      "type": "string",
      "description": "Reference to Property offered by Party A"
    },
    "propertyBId": {
      "type": "string",
      "description": "Reference to Property offered by Party B"
    },
    "matchScore": {
      "type": "number",
      "description": "Overall AI compatibility score 0\u2013100"
    },
    "criteriaMatchScore": {
      "type": "number",
      "description": "How well each property meets the other's criteria 0\u2013100"
    },
    "financialCompatibilityScore": {
      "type": "number",
      "description": "How well the valuation gap aligns with both users' budgets 0\u2013100"
    },
    "aiReasoningForA": {
      "type": "string",
      "description": "Claude's explanation for Party A of why Party B's property suits them"
    },
    "aiReasoningForB": {
      "type": "string",
      "description": "Claude's explanation for Party B of why Party A's property suits them"
    },
    "aiHighlightsForA": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "3 bullet point highlights for Party A"
    },
    "aiHighlightsForB": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "3 bullet point highlights for Party B"
    },
    "claudeModel": {
      "type": "string",
      "description": "Claude model version used for this match"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When this match was generated by AI"
    },
    "propertyAValueEGP": {
      "type": "number",
      "description": "Estimated value of Property A at time of match"
    },
    "propertyBValueEGP": {
      "type": "number",
      "description": "Estimated value of Property B at time of match"
    },
    "valuationGapEGP": {
      "type": "number",
      "description": "abs(propertyAValue - propertyBValue)"
    },
    "gapPayerUserId": {
      "type": "string",
      "description": "Reference to User whose property is worth less \u2014 they pay the gap"
    },
    "gapReceiverUserId": {
      "type": "string",
      "description": "Reference to User who receives the gap payment"
    },
    "agreedGapEGP": {
      "type": "number",
      "description": "Negotiated gap amount \u2014 may differ from AI calculation"
    },
    "status": {
      "type": "string",
      "enum": [
        "suggested",
        "a_seen",
        "b_seen",
        "a_interested",
        "b_interested",
        "both_interested",
        "negotiating",
        "terms_agreed",
        "legal_review",
        "escrow_active",
        "completed",
        "rejected",
        "expired"
      ],
      "default": "suggested",
      "description": "Current status in the match lifecycle state machine"
    },
    "negotiationStartedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When negotiation room was opened"
    },
    "termsAgreedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When both parties agreed on terms"
    },
    "termsAgreedByUserAAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when Party A agreed to terms"
    },
    "termsAgreedByUserBAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when Party B agreed to terms"
    },
    "kemeworkLegalTaskId": {
      "type": "string",
      "description": "Reference to the Kemework task created for the assigned lawyer"
    },
    "kemeworkLegalFeeEGP": {
      "type": "number",
      "description": "Legal fee charged via Kemework"
    },
    "verificationFeeAEGP": {
      "type": "number",
      "description": "Verification fee charged to Party A"
    },
    "verificationFeeBEGP": {
      "type": "number",
      "description": "Verification fee charged to Party B"
    },
    "xeedWalletEscrowReference": {
      "type": "string",
      "description": "XeedWallet escrow transaction reference"
    },
    "escrowDepositedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When funds were deposited into escrow"
    },
    "assignedSalesRepId": {
      "type": "string",
      "description": "Reference to User (admin can assign a Kemedar agent to assist)"
    },
    "salesRepAssignedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the sales rep was assigned"
    },
    "adminNotes": {
      "type": "string",
      "description": "Internal admin notes on this match"
    }
  },
  "required": [
    "intentAId",
    "intentBId",
    "userAId",
    "userBId",
    "propertyAId",
    "propertyBId"
  ]
}