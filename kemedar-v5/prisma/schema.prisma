  approvedByAdminId       String?

  offeringTitle           String
  offeringTitleAr         String?
  offeringDescription     String?
  offeringDescriptionAr   String?
  offeringSlug            String?           @unique

  propertyValuationEGP    Float?
  propertyValuationUSD    Float?
  valuationCurrencyId     String?
  valuationApprovedByAdminId String?
  valuationDate           DateTime?

  totalTokenSupply        Int
  tokenPriceEGP           Float
  tokenPriceUSD           Float?
  tokenSymbol             String?
  tokenName               String?
  tokensForSale           Int
  tokensRetainedBySeller  Int?
  tokensSold              Int               @default(0)
  tokensAvailable         Int?
  minTokensPerBuyer       Int               @default(1)
  maxTokensPerBuyer       Int?

  offeringType            FracOfferingType
  expectedAnnualYieldPercent Float?
  yieldFrequency          YieldFrequency?
  yieldCurrencyId         String?

  offeringStartDate       DateTime?
  offeringEndDate         DateTime?

  nearContractAddress     String?
  nearTokenContractDeployed Boolean         @default(false)
  nearDeployedAt          DateTime?
  nearDeployedByAdminId   String?
