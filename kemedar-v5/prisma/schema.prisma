// Kemedar v5 — Main Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ── auction ──────────────────
model PropertyAuction {
  id                      String        @id @default(cuid())
  propertyId              String        @unique
  property                Property      @relation(fields: [propertyId], references: [id])
  sellerUserId            String
  auctionCode             String        @unique

  startingPriceEGP        Float
  reservePriceEGP         Float?
  buyNowPriceEGP          Float?
  currentHighestBidEGP    Float?
  currentHighestBidderId  String?
  totalBidsCount          Int           @default(0)
  uniqueBiddersCount      Int           @default(0)

  minBidIncrementEGP      Float         @default(5000)
  sellerDepositAmountEGP  Float?
  sellerDepositPaid       Boolean       @default(false)
  buyerDepositPercent     Float         @default(1)

  auctionStartAt          DateTime?
  auctionEndAt            DateTime?
  extensionMinutes        Int           @default(5)
  maxExtensions           Int           @default(3)
  extensionsUsed          Int           @default(0)

  status                  AuctionStatus @default(draft)
  platformCommissionPercent Float       @default(2)
  winnerId                String?
  winnerPaymentDeadline   DateTime?

  auctionTitle        String?
  auctionTitleAr      String?
  auctionDescription  String?
  auctionDescriptionAr String?
  auctionType         String    @default("open")
  reserveMet          Boolean   @default(false)
  sellerDepositPaidAt DateTime?
  sellerDepositTransactionId String?
  sellerDepositRefunded Boolean @default(false)
  sellerDepositRefundedAt DateTime?
  buyerDepositAmountEGP Float?
  buyerDepositDescription String?
  registrationOpenAt  DateTime?
  registrationCloseAt DateTime?
  finalEndAt          DateTime?
  requireVerifyProLevel Int     @default(2)
  requireBuyerKYC     Boolean   @default(true)
  requireBuyerProofOfFunds Boolean @default(false)
  winnerBidEGP        Float?
  winnerNotifiedAt    DateTime?
  winnerPaymentCompletedAt DateTime?
  reviewedByAdminId   String?
  reviewedAt          DateTime?
  rejectionReason     String?
  adminNotes          String?
  isFeaturedHomepage  Boolean   @default(false)
  kemeworkLegalTaskId String?
  xeedWalletEscrowReference String?
  escrowActivatedAt   DateTime?
  totalRegisteredBidders Int    @default(0)
  totalPageViews      Int       @default(0)
  totalWatchlisted    Int       @default(0)
  peakConcurrentViewers Int     @default(0)
  deletedAt           DateTime?

  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  bids                    AuctionBid[]
  events                  AuctionEvent[]
  registrations           AuctionRegistration[]
  watchlist               AuctionWatchlist[]

  @@index([status])
  @@index([auctionStartAt, auctionEndAt])
  @@map("property_auctions")
}

model AuctionBid {
  id                    String         @id @default(cuid())
  auctionId             String
  auction               PropertyAuction @relation(fields: [auctionId], references: [id])
  bidderUserId          String
  bidder                User           @relation(fields: [bidderUserId], references: [id])
  bidAmountEGP          Float
  bidType               AuctionBidType
  isWinning             Boolean        @default(false)
  isAutoBid             Boolean        @default(false)
  autoMaxAmountEGP      Float?
  ipAddress             String?
  deviceInfo            String?
  bidSequenceNumber     Int
  wasExtended           Boolean        @default(false)
  extensionMinutesAdded Int?
  bidPlacedAt           DateTime
  createdAt             DateTime       @default(now())

  @@index([auctionId])
  @@index([bidderUserId])
  @@index([auctionId, bidAmountEGP])
  @@map("auction_bids")
}

model AuctionEvent {
  id            String           @id @default(cuid())
  auctionId     String
  auction       PropertyAuction  @relation(fields: [auctionId], references: [id])
  eventType     AuctionEventType
  actorUserId   String?
  actorType     AuctionActorType
  description   String
  metaData      Json?
  recordedAt    DateTime
  createdAt     DateTime         @default(now())

  @@index([auctionId])
  @@index([eventType])
  @@map("auction_events")
}

model AuctionRegistration {
  id                      String             @id @default(cuid())
  auctionId               String
  auction                 PropertyAuction    @relation(fields: [auctionId], references: [id])
  bidderUserId            String
  bidder                  User               @relation(fields: [bidderUserId], references: [id])
  kycVerified             Boolean            @default(false)
  proofOfFundsUploaded    Boolean            @default(false)
  proofOfFundsUrl         String?
  proofOfFundsApprovedByAdmin Boolean        @default(false)
  depositAmountEGP        Float
  depositPaid             Boolean            @default(false)
  depositPaidAt           DateTime?
  depositTransactionId    String?
  depositEscrowReference  String?
  depositStatus           DepositStatus      @default(pending)
  depositRefundedAt       DateTime?
  hasAutoBid              Boolean            @default(false)
  autoBidMaxEGP           Float?
  autoBidIncrement        Float?
  registrationStatus      RegistrationStatus @default(pending_payment)
  isWinner                Boolean            @default(false)
  totalBidsPlaced         Int                @default(0)
  highestBidPlaced        Float              @default(0)
  lastBidAt               DateTime?
  registeredAt            DateTime
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@unique([auctionId, bidderUserId])
  @@index([auctionId])
  @@index([bidderUserId])
  @@map("auction_registrations")
}

model AuctionWatchlist {
  id           String          @id @default(cuid())
  auctionId    String
  auction      PropertyAuction @relation(fields: [auctionId], references: [id])
  userId       String
  notifyOnBid  Boolean         @default(true)
  notifyOnEnd  Boolean         @default(true)
  createdAt    DateTime        @default(now())

  @@unique([auctionId, userId])
  @@map("auction_watchlists")
}

model AuctionSettings {
  id                        String   @id @default(cuid())
  isActive                  Boolean  @default(true)
  sellerDepositPercent      Float    @default(0.5)
  sellerDepositMinEGP       Float    @default(2000)
  buyerDepositPercent       Float    @default(1)
  buyerDepositMinEGP        Float    @default(5000)
  winnerPaymentDeadlineHours Int     @default(48)
  defaultMinBidIncrementEGP Float    @default(5000)
  defaultExtensionMinutes   Int      @default(5)
  defaultMaxExtensions      Int      @default(3)
  platformCommissionPercent Float    @default(2)
  requireVerifyProLevel     Int      @default(2)
  requireBuyerKYC           Boolean  @default(true)
  maxAuctionDurationDays    Int      @default(30)
  minAuctionDurationDays    Int      @default(1)
  featuredAuctionFeeEGP     Float    @default(500)
  updatedAt                 DateTime @updatedAt

  @@map("auction_settings")
}


// ── coaching ──────────────────
model CoachProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  currentJourneyId    String?
  completedJourneys   String[]
  preferences         Json?
  goals               Json?
  experienceLevel     String?
  lastActiveAt        DateTime?
  totalPointsEarned   Int      @default(0)
  streakDays          Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("coach_profiles")
}

model CoachJourney {
  id              String             @id @default(cuid())
  name            String
  nameAr          String?
  description     String?
  descriptionAr   String?
  targetRole      String?
  steps           Json?
  totalSteps      Int                @default(0)
  estimatedMinutes Int?
  isActive        Boolean            @default(true)
  sortOrder       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("coach_journeys")
}

model CoachContent {
  id              String   @id @default(cuid())
  title           String
  titleAr         String?
  contentType     String
  body            String?
  bodyAr          String?
  mediaUrl        String?
  category        String?
  tags            String[]
  targetRoles     String[]
  isActive        Boolean  @default(true)
  viewCount       Int      @default(0)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("coach_contents")
}

model CoachMessage {
  id              String   @id @default(cuid())
  userId          String
  role            String
  content         String
  contentAr       String?
  isAiGenerated   Boolean  @default(false)
  journeyId       String?
  stepIndex       Int?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@map("coach_messages")
}

model CoachAchievement {
  id              String   @id @default(cuid())
  userId          String
  achievementType String
  title           String
  titleAr         String?
  description     String?
  points          Int      @default(0)
  iconUrl         String?
  earnedAt        DateTime @default(now())

  @@index([userId])
  @@map("coach_achievements")
}

model CoachNudge {
  id              String   @id @default(cuid())
  userId          String
  nudgeType       String
  title           String
  titleAr         String?
  message         String
  messageAr       String?
  actionUrl       String?
  isRead          Boolean  @default(false)
  isDismissed     Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([userId])
  @@map("coach_nudges")
}


// ── community ──────────────────
model Community {
  id                String   @id @default(cuid())
  name              String
  nameAr            String?
  description       String?
  descriptionAr     String?
  type              CommunityType @default(compound)
  coverImageUrl     String?
  logoUrl           String?

  countryId         String?
  provinceId        String?
  cityId            String?
  districtId        String?
  compoundName      String?

  isVerified        Boolean  @default(false)
  isActive          Boolean  @default(true)
  isPublic          Boolean  @default(true)

  membersCount      Int      @default(0)
  postsCount        Int      @default(0)

  rules             Json?
  features          String[]
  tags              String[]

  createdByUserId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  communityNumber     String?   @unique
  privacyLevel        String    @default("public")
  areaId              String?
  compoundId          String?
  buildingNumber      String?
  coordinates         Json?
  activeMembers       Int       @default(0)
  pendingMembers      Int       @default(0)
  membershipRequirements Json?
  franchiseOwnerId    String?
  adminUserIds        String[]
  moderatorUserIds    String[]
  allowMemberPosts    Boolean   @default(true)
  allowMarketplace    Boolean   @default(true)
  allowPolls          Boolean   @default(true)
  allowAlerts         Boolean   @default(true)
  allowAnnouncements  Boolean   @default(true)
  requirePostApproval Boolean   @default(false)
  totalMarketplaceItems Int     @default(0)
  postsThisWeek       Int       @default(0)
  status              String    @default("active")
  kemetroGroupBuyEnabled Boolean @default(false)

  members           CommunityMember[]
  posts             CommunityPost[]
  events            CommunityEvent[]
  alerts            CommunityAlert[]

  @@index([cityId])
  @@index([type])
  @@map("communities")
}

model CommunityMember {
  id            String            @id @default(cuid())
  communityId   String
  community     Community         @relation(fields: [communityId], references: [id])
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  role          CommunityMemberRole @default(member)
  unitNumber    String?
  isVerified    Boolean           @default(false)
  joinedAt      DateTime          @default(now())
  leftAt        DateTime?

  @@unique([communityId, userId])
  @@map("community_members")
}

model CommunityPost {
  id              String          @id @default(cuid())
  communityId     String
  community       Community       @relation(fields: [communityId], references: [id])
  authorUserId    String
  author          User            @relation(fields: [authorUserId], references: [id])

  postType        CommunityPostType @default(general)
  title           String?
  titleAr         String?
  content         String
  contentAr       String?
  imageUrls       String[]
  attachmentUrls  String[]

  isPinned        Boolean         @default(false)
  isAnonymous     Boolean         @default(false)

  likesCount      Int             @default(0)
  commentsCount   Int             @default(0)
  sharesCount     Int             @default(0)

  moderationStatus ModerationStatus @default(pending)
  moderatedByUserId String?
  moderatedAt     DateTime?
  moderationNotes String?

  pollOptions     Json?
  pollVotes       Json?

  linkUrl             String?
  pinnedUntil         DateTime?
  pinnedBy            String?
  isAnnouncement      Boolean   @default(false)
  announcementUrgency String?
  requiresAction      Boolean   @default(false)
  actionDeadline      DateTime?
  visibility          String    @default("community")
  viewCount           Int       @default(0)
  reactionsCount      Int       @default(0)
  reactions           Json?
  reportCount         Int       @default(0)
  pollEndsAt          DateTime?
  pollMultipleChoice  Boolean   @default(false)
  pollAnonymous       Boolean   @default(false)
  totalPollVotes      Int       @default(0)
  pollVoterIds        String[]
  alertType           String?
  alertArea           String?
  alertStartsAt       DateTime?
  alertEndsAt         DateTime?
  alertResolved       Boolean   @default(false)
  alertResolvedAt     DateTime?
  alertConfirmations  Int       @default(0)
  alertConfirmingUserIds String[]
  marketplaceItemId   String?
  suggestedKemeworkCategory String?
  kemeworkTaskCreated Boolean   @default(false)
  kemeworkTaskId      String?
  aiModerated         Boolean   @default(false)
  aiModerationScore   Float?
  aiCategoryDetected  String?
  expiresAt           DateTime?

  tags            String[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  comments        CommunityComment[]

  @@index([communityId])
  @@index([authorUserId])
  @@index([postType])
  @@map("community_posts")
}

model CommunityComment {
  id              String        @id @default(cuid())
  postId          String
  post            CommunityPost @relation(fields: [postId], references: [id])
  authorUserId    String
  content         String
  contentAr       String?
  parentCommentId String?
  likesCount      Int           @default(0)
  moderationStatus ModerationStatus @default(approved)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([postId])
  @@map("community_comments")
}

model CommunityEvent {
  id              String    @id @default(cuid())
  communityId     String
  community       Community @relation(fields: [communityId], references: [id])
  title           String
  titleAr         String?
  description     String?
  descriptionAr   String?
  eventType       String?
  location        String?
  startAt         DateTime?
  endAt           DateTime?
  imageUrl        String?
  maxAttendees    Int?
  rsvpCount       Int       @default(0)
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([communityId])
  @@map("community_events")
}

model CommunityAlert {
  id              String    @id @default(cuid())
  communityId     String
  community       Community @relation(fields: [communityId], references: [id])
  alertType       String
  title           String
  titleAr         String?
  description     String?
  descriptionAr   String?
  severity        String    @default("info")
  isActive        Boolean   @default(true)
  expiresAt       DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([communityId])
  @@map("community_alerts")
}

model CommunityRecommendation {
  id              String   @id @default(cuid())
  communityId     String
  recommendedByUserId String
  serviceType     String
  title           String
  description     String?
  rating          Int?
  contactInfo     String?
  likesCount      Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([communityId])
  @@map("community_recommendations")
}


// ── concierge ──────────────────
model ConciergeJourney {
  id              String              @id @default(cuid())
  userId          String
  propertyId      String?
  templateId      String?
  journeyType     String
  status          String              @default("active")
  completionPercent Float             @default(0)
  moveInDate      DateTime?
  startedAt       DateTime            @default(now())
  completedAt     DateTime?
  dismissedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tasks           ConciergeTask[]

  @@index([userId])
  @@map("concierge_journeys")
}

model ConciergeJourneyTemplate {
  id              String   @id @default(cuid())
  name            String
  nameAr          String?
  journeyType     String
  propertyType    String?
  countryId       String?
  cityId          String?
  steps           Json?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("concierge_journey_templates")
}

model ConciergeTask {
  id              String            @id @default(cuid())
  journeyId       String
  journey         ConciergeJourney  @relation(fields: [journeyId], references: [id])
  templateTaskId  String?
  title           String
  titleAr         String?
  description     String?
  descriptionAr   String?
  category        String?
  priority        String?           @default("medium")
  status          ConciergeTaskStatus @default(pending)
  dueDate         DateTime?
  completedAt     DateTime?
  skippedAt       DateTime?
  sortOrder       Int               @default(0)
  actionUrl       String?
  notes           String?
  assignedToUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([journeyId])
  @@map("concierge_tasks")
}

model ConciergeTaskTemplate {
  id              String   @id @default(cuid())
  title           String
  titleAr         String?
  description     String?
  descriptionAr   String?
  category        String?
  defaultPriority String?  @default("medium")
  estimatedDays   Int?
  actionUrl       String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@map("concierge_task_templates")
}


// ── construction ──────────────────
model BuildProject {
  id                  String   @id @default(cuid())
  userId              String
  title               String
  titleAr             String?
  description         String?
  projectType         String?
  floorPlanUrl        String?
  floorPlanAnalysis   Json?
  totalAreaSqm        Float?
  rooms               Json?
  estimatedCostEGP    Float?
  costBreakdown       Json?
  boqGenerated        Boolean  @default(false)
  boqItems            Json?
  laborEstimate       Float?
  materialEstimate    Float?
  status              String   @default("draft")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@map("build_projects")
}

model FinishProject {
  id                  String              @id @default(cuid())
  userId              String
  propertyId          String?
  title               String
  titleAr             String?
  description         String?
  projectType         String?
  totalAreaSqm        Float?

  budgetMinEGP        Float?
  budgetMaxEGP        Float?
  actualSpentEGP      Float?

  status              FinishProjectStatus @default(draft)
  currentPhaseId      String?
  completionPercent   Float               @default(0)

  startDate           DateTime?
  expectedEndDate     DateTime?
  actualEndDate       DateTime?

  contractorId        String?
  supervisorId        String?

  qualityScore        Float?
  snaggingCount       Int                 @default(0)

  projectNumber       String?   @unique
  propertyType        String?
  numberOfRooms       Int?
  numberOfBathrooms   Int?
  floorNumber         Int?
  propertyAddress     String?
  cityId              String?
  districtId          String?
  designStyle         String?
  colorPalette        Json?
  finishingLevel      String?
  floorPlanUrl        String?
  floorPlanAiExtracted Boolean  @default(false)
  approvedBudget      Float?
  budgetCurrency      String    @default("EGP")
  budgetBreakdown     Json?
  boqStatus           String    @default("not_generated")
  boqData             Json?
  boqApprovedAt       DateTime?
  boqApprovedBy       String?
  estimatedDurationWeeks Int?
  currentPhaseStatus  String?
  franchiseOwnerId    String?
  projectManagerId    String?
  assignedProfessionals Json?
  escrowDealId        String?
  totalEscrowAmount   Float?
  requiresFOSupervision Boolean @default(false)
  foInspectionCount   Int       @default(0)
  hasActiveSnaggingList Boolean @default(false)
  ownerSatisfactionRating Float?
  aiProjectSummary    String?
  aiRiskFlags         Json?
  aiRecommendations   String[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  phases              FinishPhase[]
  boqs                FinishBOQ[]
  materialOrders      FinishMaterialOrder[]
  progressUpdates     FinishProgressUpdate[]
  snaggingItems       FinishSnaggingItem[]
  inspectionReports   FOInspectionReport[]

  @@index([userId])
  @@index([status])
  @@map("finish_projects")
}

model FinishPhase {
  id              String        @id @default(cuid())
  projectId       String
  project         FinishProject @relation(fields: [projectId], references: [id])
  phaseName       String
  phaseNameAr     String?
  phaseOrder      Int
  description     String?
  status          String        @default("pending")
  budgetEGP       Float?
  actualCostEGP   Float?
  completionPercent Float       @default(0)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([projectId])
  @@map("finish_phases")
}

model FinishBOQ {
  id              String        @id @default(cuid())
  projectId       String
  project         FinishProject @relation(fields: [projectId], references: [id])
  title           String?
  totalCostEGP    Float?
  laborCostEGP    Float?
  materialCostEGP Float?
  items           Json?
  sections        Json?
  generatedByAI   Boolean       @default(false)
  version         Int           @default(1)
  status          String        @default("draft")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([projectId])
  @@map("finish_boqs")
}

model FinishMaterialOrder {
  id              String        @id @default(cuid())
  projectId       String
  project         FinishProject @relation(fields: [projectId], references: [id])
  itemName        String
  quantity        Float
  unit            String?
  pricePerUnit    Float?
  totalPrice      Float?
  supplierId      String?
  status          String        @default("pending")
  orderedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([projectId])
  @@map("finish_material_orders")
}

model FinishProgressUpdate {
  id              String        @id @default(cuid())
  projectId       String
  project         FinishProject @relation(fields: [projectId], references: [id])
  phaseId         String?
  description     String?
  photoUrls       String[]
  completionPercent Float?
  qualityScore    Float?
  aiAnalysis      Json?
  reportedByUserId String?
  createdAt       DateTime      @default(now())

  @@index([projectId])
  @@map("finish_progress_updates")
}

model FinishSnaggingItem {
  id              String        @id @default(cuid())
  projectId       String
  project         FinishProject @relation(fields: [projectId], references: [id])
  phaseId         String?
  title           String
  description     String?
  severity        String        @default("medium")
  photoUrls       String[]
  location        String?
  status          String        @default("open")
  assignedToId    String?
  resolvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([projectId])
  @@map("finish_snagging_items")
}

model BOQItem {
  id              String   @id @default(cuid())
  name            String
  nameAr          String?
  category        String?
  unit            String?
  pricePerUnitEGP Float?
  calcRule        BOQItemCalcRule @default(per_sqm)
  coverageSqm     Float?
  wasteMargin     Float?   @default(0.1)
  parentItemId    String?
  ratioToParent   Float?
  isOptional      Boolean  @default(false)
  kemetroKeywords String[]
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("boq_items")
}

model FinishingCostIndex {
  id              String   @id @default(cuid())
  material        String
  category        String?
  pricePerUnitEGP Float
  unit            String
  region          String?
  cityId          String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@map("finishing_cost_indices")
}

model FinishingSimulation {
  id              String   @id @default(cuid())
  userId          String?
  projectId       String?
  scenario        String?
  inputParams     Json?
  results         Json?
  totalEstimateEGP Float?
  createdAt       DateTime @default(now())

  @@map("finishing_simulations")
}

model FOInspectionReport {
  id              String        @id @default(cuid())
  projectId       String
  project         FinishProject @relation(fields: [projectId], references: [id])
  inspectorUserId String
  inspectionType  String
  overallScore    Float?
  findings        Json?
  photoUrls       String[]
  recommendations String?
