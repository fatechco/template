  userId              String
  user                User       @relation(fields: [userId], references: [id])
  offeredPropertyId   String     @unique
  offeredProperty     Property   @relation(fields: [offeredPropertyId], references: [id])

  desiredCategories   String[]
  desiredCityIds      String[]
  desiredProvinceIds  String[]
  desiredDistrictIds  String[]
  desiredMinArea      Float?
  desiredMaxArea      Float?
  desiredMinBedrooms  Int?
  desiredMaxBedrooms  Int?
  desiredMinBathrooms Int?

  acceptsCashGap      Boolean    @default(true)
  maxCashGapPayEGP    Float?
  maxCashGapReceiveEGP Float?

  status              SwapStatus @default(draft)
  totalMatches        Int        @default(0)
  publishedAt         DateTime?
  expiresAt           DateTime?

  notes               String?
  notesAr             String?

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  matchesAsA          SwapMatch[] @relation("SwapMatchA")
  matchesAsB          SwapMatch[] @relation("SwapMatchB")

  @@index([userId])
  @@index([status])
  @@map("swap_intents")
}

model SwapMatch {
  id              String          @id @default(cuid())
  intentAId       String
  intentA         SwapIntent      @relation("SwapMatchA", fields: [intentAId], references: [id])
  intentBId       String
  intentB         SwapIntent      @relation("SwapMatchB", fields: [intentBId], references: [id])
  matchScore      Float?
  matchReasons    Json?
  cashGapAmount   Float?
  cashGapDirection String?
  status          SwapMatchStatus @default(pending)
  aInterested     Boolean         @default(false)
  bInterested     Boolean         @default(false)
  negotiationId   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  gapOffers       SwapGapOffer[]
  messages        SwapNegotiationMessage[]

  @@unique([intentAId, intentBId])
  @@index([intentAId])
  @@index([intentBId])
  @@map("swap_matches")
}

model SwapGapOffer {
  id           String    @id @default(cuid())
  matchId      String
  match        SwapMatch @relation(fields: [matchId], references: [id])
  offeredById  String
  amountEGP    Float
  direction    String
  status       String    @default("pending")
  respondedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([matchId])
  @@map("swap_gap_offers")
}

model SwapNegotiationMessage {
  id          String    @id @default(cuid())
  matchId     String
  match       SwapMatch @relation(fields: [matchId], references: [id])
  senderUserId String
  content     String
  contentAr   String?
  messageType String    @default("text")
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([matchId])
  @@map("swap_negotiation_messages")
}

model SwapSettings {
  id                  String   @id @default(cuid())
  isActive            Boolean  @default(true)
  requireVerifyPro    Int      @default(2)
  maxActiveIntents    Int      @default(3)
  matchExpiryDays     Int      @default(30)
  updatedAt           DateTime @updatedAt

  @@map("swap_settings")
}


// ── user ──────────────────
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String?
  name              String?
  nameAr            String?
  phone             String?
  avatarUrl         String?
  role              UserRole  @default(user)
  isActive          Boolean   @default(true)
  isVerified        Boolean   @default(false)
  agreedToTerms     Boolean   @default(false)
  agreedToTermsAt   DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  properties              Property[]
  escrowDealsAsBuyer      EscrowDeal[]    @relation("EscrowBuyer")
  escrowDealsAsSeller     EscrowDeal[]    @relation("EscrowSeller")
  auctionRegistrations    AuctionRegistration[]
  auctionBids             AuctionBid[]
  fracTokens              FracToken[]
  swapIntents             SwapIntent[]
  communityMemberships    CommunityMember[]
  communityPosts          CommunityPost[]
  subscriptions           Subscription[]
  userDna                 UserDNA?
  kemedarScore            KemedarScore?
  coachProfile            CoachProfile?
  advisorProfile          AdvisorProfile?
  matchProfile            MatchProfile?
  blockchainWallets       BlockchainWallet[]
  scoreEvents             ScoreEvent[]
  serviceOrders           ServiceOrder[]
  qrCodes                 QRCode[]
  verificationDocuments   VerificationDocument[]
  verificationRecords     VerificationRecord[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model UserDNA {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  preferredPropertyTypes String[]
  preferredLocations     String[]
  budgetMin              Float?
  budgetMax              Float?
  preferredCurrency      String?
  lifestylePriorities    Json?
  investmentStyle        String?
  riskTolerance          String?
  searchBehavior         Json?
  interactionHistory     Json?
  calculatedAt           DateTime?
  version                Int       @default(1)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("user_dna")
}

model UserSubscription {
  id              String   @id @default(cuid())
  userId          String
  subscriptionId  String
  status          String   @default("active")
  startDate       DateTime
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("user_subscriptions")
}

model BlockchainWallet {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  walletAddress   String
  networkType     NearNetworkType @default(testnet)
  isPrimary       Boolean  @default(false)
  balance         Float?
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, walletAddress])
  @@map("blockchain_wallets")
}

