  @@map("keme_kit_settings")
}

model DistanceField {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  category    String?
  icon        String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("distance_fields")
}

model ProjectDistance {
  id          String   @id @default(cuid())
  projectId   String
  poiName     String
  poiNameAr   String?
  poiType     String?
  distanceKm  Float?
  durationMins Float?
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@map("project_distances")
}
