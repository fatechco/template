  createdAt       DateTime @default(now())

  @@map("hotspot_sponsorship_logs")
}

model ValuationPortfolio {
  id              String   @id @default(cuid())
  userId          String
  propertyIds     String[]
  totalValueEGP   Float?
  lastCalculatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("valuation_portfolios")
}

model DeveloperEcoScore {
  id              String   @id @default(cuid())
  developerId     String
  overallScore    Float?
  dimensions      Json?
  projectCount    Int?     @default(0)
  calculatedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([developerId])
  @@map("developer_eco_scores")
}

model ThinkDarAPIRequest {
  id              String   @id @default(cuid())
  userId          String?
  requestType     String
  inputData       Json?
  outputData      Json?
  status          String   @default("pending")
  processingTime  Float?
  createdAt       DateTime @default(now())

  @@map("thinkdar_api_requests")
}

model SnapSession {
  id              String   @id @default(cuid())
  userId          String
  imageUrl        String?
  analysis        Json?
  materialMatches Json?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("snap_sessions")
}

model SnapSettings {
  id          String   @id @default(cuid())
  isActive    Boolean  @default(true)
  maxDailySessions Int @default(10)
  updatedAt   DateTime @updatedAt

  @@map("snap_settings")
}

model SnapMaterialCartItem {
