  stockQty        Int?
  kemetroProductId String?
  tags            String[]
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("keme_kit_items")
}

model KemeKitTemplate {
  id              String   @id @default(cuid())
  name            String
  nameAr          String?
  roomType        String?
  items           Json?
  totalEstimate   Float?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("keme_kit_templates")
}

model KemeKitCalculation {
  id              String   @id @default(cuid())
  userId          String
  projectId       String?
  rooms           Json?
  items           Json?
  totalMaterialCost Float?
  totalLaborCost    Float?
  totalShippingCost Float?
