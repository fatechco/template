  @@index([userId])
  @@map("keme_kit_saves")
}

model KemeKitSettings {
  id              String   @id @default(cuid())
  isActive        Boolean  @default(true)
  defaultWasteMargin Float @default(0.1)
  shippingRatePerKg  Float @default(15)
