model MatchProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  preferences     Json?
  budgetRange     Json?
  locationPrefs   Json?
  lifestylePrefs  Json?
  dealBreakers    String[]
  lastUpdatedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("match_profiles")
}

model MatchQueue {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String
  score       Float?
  reasons     Json?
  isViewed    Boolean  @default(false)
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("match_queues")
}

model MatchInsight {
  id          String   @id @default(cuid())
  userId      String
  insightType String
  title       String?
  description String?
  data        Json?
  confidence  Float?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("match_insights")
}

model AdvisorProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  purpose             String?
  householdSize       Int?
  monthlyIncomeEGP    Float?
  budgetEGP           Float?
  priorities          Json?
  preferredLocations  String[]
  preferredTypes      String[]
  timeline            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("advisor_profiles")
}

model AdvisorMatch {
  id              String   @id @default(cuid())
  advisorProfileId String
  propertyId      String
  matchScore      Float?
  matchReasons    Json?
  userAction      String?
  viewedAt        DateTime?
  createdAt       DateTime @default(now())

  @@index([advisorProfileId])
  @@map("advisor_matches")
}

model AdvisorReport {
  id              String   @id @default(cuid())
  userId          String
  profileId       String
  title           String?
  recommendations Json?
  financialAnalysis Json?
  locationRankings Json?
  shareToken      String?  @unique
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@map("advisor_reports")
}

model ServiceOrder {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  serviceType     String
  title           String
  description     String?
  status          ServiceOrderStatus @default(pending)
  priorityLevel   String?            @default("normal")
  assignedToId    String?
  estimatedCostEGP Float?
  actualCostEGP   Float?
  scheduledAt     DateTime?
  completedAt     DateTime?
  rating          Int?
  review          String?
  location        String?
  cityId          String?
  imageUrls       String[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  activities      ServiceOrderActivity[]

  @@index([userId])
  @@index([status])
  @@map("service_orders")
}

model ServiceOrderActivity {
  id          String       @id @default(cuid())
  orderId     String
  order       ServiceOrder @relation(fields: [orderId], references: [id])
  activityType String
  description String?
  performedByUserId String?
  createdAt   DateTime     @default(now())

  @@index([orderId])
  @@map("service_order_activities")
}

model Translation {
  id          String   @id @default(cuid())
  key         String
  module      String
  locale      String
  value       String
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, module, locale])
  @@index([module, locale])
  @@map("translations")
}

model TranslationLocation {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  locale      String
  field       String
  value       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([entityType, entityId, locale, field])
  @@map("translation_locations")
}

model VerificationDocument {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  documentType    String
  fileUrl         String
  status          String   @default("pending")
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("verification_documents")
}

model VerificationRecord {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  propertyId      String?
  level           Int
  action          String
  hashChain       String?
  previousHash    String?
  metaData        Json?
  verifiedByUserId String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([propertyId])
  @@map("verification_records")
}

model CompoundDeal {
  id              String   @id @default(cuid())
  propertyId      String?
  dealType        String?
  title           String
  description     String?
  participants    Json?
  totalValueEGP   Float?
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("compound_deals")
}

model FranchiseCommission {
  id              String   @id @default(cuid())
  franchiseOwnerId String
  sourceType      String
  sourceId        String?
  amountEGP       Float
  percent         Float?
  status          String   @default("pending")
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  @@index([franchiseOwnerId])
  @@map("franchise_commissions")
}

model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  discountType    String
  discountValue   Float
  maxUses         Int?
  usedCount       Int      @default(0)
  validFrom       DateTime?
  validTo         DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@map("promo_codes")
}

model UsageEvent {
  id          String   @id @default(cuid())
  userId      String?
  sessionId   String?
  eventType   String
  eventData   Json?
  page        String?
  referrer    String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@map("usage_events")
}

model MarketIntelligenceReport {
  id              String   @id @default(cuid())
  title           String
  reportType      String?
  region          String?
  cityId          String?
  content         Json?
  summary         String?
  publishedAt     DateTime?
  createdAt       DateTime @default(now())

  @@map("market_intelligence_reports")
}

model MarketSignal {
  id          String   @id @default(cuid())
  signalType  String
  region      String?
  cityId      String?
  value       Float?
  trend       String?
  source      String?
  data        Json?
  recordedAt  DateTime?
  createdAt   DateTime @default(now())

  @@map("market_signals")
}

model MarketProfile {
  id          String   @id @default(cuid())
  region      String
  cityId      String?
  profileData Json?
  metrics     Json?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("market_profiles")
}

model MarketPriceIndex {
  id              String   @id @default(cuid())
  region          String?
  cityId          String?
  propertyType    String?
  pricePerSqm     Float?
  currency        String   @default("EGP")
  period          String?
  trend           String?
  createdAt       DateTime @default(now())

  @@map("market_price_indices")
}

model DemandSignal {
  id          String   @id @default(cuid())
  signalType  String
  category    String?
  region      String?
  strength    Float?
  data        Json?
  createdAt   DateTime @default(now())

  @@map("demand_signals")
}

model CrossMarketSearch {
  id          String   @id @default(cuid())
  userId      String?
  query       Json?
  results     Json?
  markets     String[]
  createdAt   DateTime @default(now())

  @@map("cross_market_searches")
}

model InvestmentMetric {
  id              String   @id @default(cuid())
  propertyId      String?
  metricType      String
  value           Float?
  currency        String   @default("EGP")
  period          String?
  calculatedAt    DateTime?
  createdAt       DateTime @default(now())

  @@map("investment_metrics")
}

model PricePrediction {
  id              String   @id @default(cuid())
  propertyId      String?
  locationId      String?
  predictedPrice  Float?
  confidence      Float?
  timeframeMonths Int?
  factors         Json?
  createdAt       DateTime @default(now())

  @@map("price_predictions")
}

model PredictSubscription {
  id          String   @id @default(cuid())
  userId      String
  locationId  String?
  propertyType String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("predict_subscriptions")
}

model PredictionHistoricalTrack {
  id              String   @id @default(cuid())
  predictionId    String
  actualPrice     Float?
  accuracy        Float?
  checkedAt       DateTime?
  createdAt       DateTime @default(now())

  @@map("prediction_historical_tracks")
}

model PersonalizationRule {
  id          String   @id @default(cuid())
  name        String
  conditions  Json?
  actions     Json?
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("personalization_rules")
}

model PersonalizedFeed {
  id          String   @id @default(cuid())
  userId      String
  feedItems   Json?
  generatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("personalized_feeds")
}

model RelocationProfile {
  id              String   @id @default(cuid())
  userId          String
  fromCountry     String?
  fromCity        String?
  toCountry       String?
  toCity          String?
  timeline        String?
  budget          Float?
  needs           Json?
  matchScore      Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("relocation_profiles")
}

model ImageHotspot {
  id              String   @id @default(cuid())
  imageUrl        String
  propertyId      String?
